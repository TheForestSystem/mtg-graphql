generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "user_data"]
}

model User {
  uuid         String       @id(map: "users_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String       @unique(map: "users_username_uk") @db.VarChar(50)
  displayName  String?      @map("display_name") @db.VarChar(50)
  email        String       @unique(map: "users_email_uk") @db.VarChar(100)
  passwordHash String       @map("password_hash")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  collection   Collection[]
  decks        Deck[]

  @@map("users")
  @@schema("user_data")
}

model Deck {
  id        String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String
  format    String?
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  userUuid  String     @db.Uuid
  user      User       @relation(fields: [userUuid], references: [uuid], onDelete: Cascade, onUpdate: NoAction, map: "fk_deck_user")
  cards     DeckCard[]

  @@index([userUuid], map: "idx_deck_useruuid")
  @@map("deck")
  @@schema("user_data")
}

model DeckCard {
  id          String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  deckId      String
  cardUuid    String
  quantity    Int     @default(1)
  isSideboard Boolean @default(false)
  isCommander Boolean @default(false)
  cards       cards   @relation(fields: [cardUuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction, map: "fk_deckcard_card")
  deck        Deck    @relation(fields: [deckId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_deckcard_deck")

  @@index([cardUuid], map: "idx_deckcard_carduuid")
  @@index([deckId], map: "idx_deckcard_deckid")
  @@map("deckCard")
  @@schema("user_data")
}

model Collection {
  id       String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  cardUuid String
  quantity Int     @default(1)
  foil     Boolean @default(false)
  userUuid String  @db.Uuid
  cards    cards   @relation(fields: [cardUuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction, map: "fk_collection_card")
  user     User    @relation(fields: [userUuid], references: [uuid], onDelete: Cascade, onUpdate: NoAction, map: "fk_collection_user")

  @@index([cardUuid], map: "idx_collection_carduuid")
  @@index([userUuid], map: "idx_collection_useruuid")
  @@map("collection")
  @@schema("user_data")
}

model cardForeignData {
  uuid         String?
  faceName     String?
  skuIds       String?
  flavorText   String?
  identifiers  String?
  language     String?
  multiverseId Int?
  name         String?
  text         String?
  type         String?
  id           Int     @id @default(autoincrement())
  cards        cards?  @relation(fields: [uuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction, map: "fk_cardforeigndata_uuid")

  @@index([language], map: "idx_cardForeignData_language")
  @@index([uuid], map: "idx_cardForeignData_uuid")
  @@schema("public")
}

model cardIdentifiers {
  uuid                              String  @id
  scryfallId                        String?
  scryfallOracleId                  String?
  scryfallIllustrationId            String?
  scryfallCardBackId                String?
  mcmId                             String?
  mcmMetaId                         String?
  mtgArenaId                        String?
  mtgoId                            String?
  mtgoFoilId                        String?
  multiverseId                      String?
  tcgplayerProductId                String?
  tcgplayerEtchedProductId          String?
  tcgplayerAlternativeFoilProductId String?
  cardKingdomId                     String?
  cardKingdomFoilId                 String?
  cardKingdomEtchedId               String?
  cardsphereId                      String?
  cardsphereAlternativeFoilId       String?
  cardsphereEtchedId                String?
  cardsphereFoilId                  String?
  deckboxId                         String?
  mtgjsonFoilVersionId              String?
  mtgjsonNonFoilVersionId           String?
  mtgjsonV4Id                       String?
  cards                             cards   @relation(fields: [uuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction, map: "fk_cardidentifiers_uuid")

  @@index([uuid], map: "idx_cardIdentifiers_uuid")
  @@schema("public")
}

model cardLegalities {
  uuid            String  @id
  alchemy         String?
  brawl           String?
  commander       String?
  duel            String?
  future          String?
  gladiator       String?
  historic        String?
  legacy          String?
  modern          String?
  oathbreaker     String?
  oldschool       String?
  pauper          String?
  paupercommander String?
  penny           String?
  pioneer         String?
  predh           String?
  premodern       String?
  standard        String?
  standardbrawl   String?
  timeless        String?
  tlr             String?
  vintage         String?
  cards           cards   @relation(fields: [uuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction, map: "fk_cardlegalities_uuid")

  @@index([uuid], map: "idx_cardLegalities_uuid")
  @@schema("public")
}

model cardPurchaseUrls {
  uuid                     String  @id
  cardKingdom              String?
  cardKingdomFoil          String?
  cardKingdomEtched        String?
  cardmarket               String?
  cardmarketFoil           String?
  tcgplayer                String?
  tcgplayerEtched          String?
  tcgplayerAlternativeFoil String?
  cards                    cards   @relation(fields: [uuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction, map: "fk_cardpurchaseurls_uuid")

  @@index([uuid], map: "idx_cardPurchaseUrls_uuid")
  @@schema("public")
}

model cardRulings {
  uuid  String?
  date  DateTime? @db.Date
  text  String?
  id    Int       @id @default(autoincrement())
  cards cards?    @relation(fields: [uuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction, map: "fk_cardrulings_uuid")

  @@index([uuid], map: "idx_cardRulings_uuid")
  @@schema("public")
}

model cards {
  artist                  String?
  artistIds               String?
  asciiName               String?
  attractionLights        String?
  availability            String?
  boosterTypes            String?
  borderColor             String?
  cardParts               String?
  colorIdentity           String?
  colorIndicator          String?
  colors                  String?
  defense                 String?
  duelDeck                String?
  edhrecRank              Int?
  edhrecSaltiness         Float?
  faceConvertedManaCost   Float?
  faceFlavorName          String?
  faceManaValue           Float?
  faceName                String?
  facePrintedName         String?
  finishes                String?
  flavorName              String?
  flavorText              String?
  frameEffects            String?
  frameVersion            String?
  hand                    String?
  hasAlternativeDeckLimit Boolean?
  hasContentWarning       Boolean?
  isAlternative           Boolean?
  isFullArt               Boolean?
  isFunny                 Boolean?
  isGameChanger           Boolean?
  isOnlineOnly            Boolean?
  isOversized             Boolean?
  isPromo                 Boolean?
  isRebalanced            Boolean?
  isReprint               Boolean?
  isReserved              Boolean?
  isStorySpotlight        Boolean?
  isTextless              Boolean?
  isTimeshifted           Boolean?
  keywords                String?
  language                String?
  layout                  String?
  leadershipSkills        String?
  life                    String?
  loyalty                 String?
  manaCost                String?
  manaValue               Float?
  name                    String?
  number                  String?
  originalPrintings       String?
  originalReleaseDate     String?
  originalText            String?
  otherFaceIds            String?
  power                   String?
  printedName             String?
  printedText             String?
  printedType             String?
  printings               String?
  producedMana            String?
  promoTypes              String?
  rarity                  String?
  rebalancedPrintings     String?
  relatedCards            String?
  securityStamp           String?
  setCode                 String?
  side                    String?
  signature               String?
  skuIds                  String?
  sourceProducts          String?
  subsets                 String?
  subtypes                String?
  supertypes              String?
  text                    String?
  toughness               String?
  type                    String?
  types                   String?
  uuid                    String            @id
  variations              String?
  watermark               String?
  colors_arr              String[]
  colorIdentity_arr       String[]
  cardForeignData         cardForeignData[]
  cardIdentifiers         cardIdentifiers?
  cardLegalities          cardLegalities?
  cardPurchaseUrls        cardPurchaseUrls?
  cardRulings             cardRulings[]
  sets                    sets?             @relation(fields: [setCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_cards_setcode")
  collection              Collection[]
  deckCard                DeckCard[]

  @@index([colorIdentity_arr], map: "idx_cards_coloridentity_arr", type: Gin)
  @@index([colors_arr], map: "idx_cards_colors_arr", type: Gin)
  @@index([name], map: "idx_cards_name")
  @@index([setCode], map: "idx_cards_setCode")
  @@index([uuid], map: "idx_cards_uuid")
  @@schema("public")
}

model meta {
  date    String?
  version String?
  id      Int     @id @default(autoincrement())

  @@schema("public")
}

model sealedProducts {
  setCode      String?
  cardCount    Int?
  category     String?
  contents     String?
  identifiers  String?
  name         String?
  productSize  String?
  purchaseUrls String?
  releaseDate  String?
  subtype      String?
  uuid         String  @id
  sets         sets?   @relation(fields: [setCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_sealedproducts_setcode")

  @@index([setCode], map: "idx_sealedProducts_setCode")
  @@index([uuid], map: "idx_sealedProducts_uuid")
  @@schema("public")
}

model setBoosterContentWeights {
  setCode       String?
  boosterName   String?
  boosterIndex  Int?
  boosterWeight BigInt?
  id            Int     @id @default(autoincrement())
  sets          sets?   @relation(fields: [setCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_setboostercontentweights_setcode")

  @@index([setCode], map: "idx_setBoosterContentWeights_setCode")
  @@schema("public")
}

model setBoosterContents {
  setCode      String?
  boosterName  String?
  boosterIndex Int?
  sheetName    String?
  sheetPicks   Int?
  id           Int     @id @default(autoincrement())
  sets         sets?   @relation(fields: [setCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_setboostercontents_setcode")

  @@index([setCode], map: "idx_setBoosterContents_setCode")
  @@schema("public")
}

model setBoosterSheetCards {
  setCode     String?
  boosterName String?
  sheetName   String?
  cardUuid    String?
  cardWeight  BigInt?
  id          Int     @id @default(autoincrement())
  sets        sets?   @relation(fields: [setCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_setboostersheetcards_setcode")

  @@index([cardUuid], map: "idx_setBoosterSheetCards_cardUuid")
  @@index([setCode], map: "idx_setBoosterSheetCards_setCode")
  @@schema("public")
}

model setBoosterSheets {
  setCode               String?
  boosterName           String?
  sheetName             String?
  sheetIsFoil           Boolean?
  sheetHasBalanceColors Boolean?
  sheetTotalWeight      BigInt?
  id                    Int      @id @default(autoincrement())
  sets                  sets?    @relation(fields: [setCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_setboostersheets_setcode")

  @@index([setCode], map: "idx_setBoosterSheets_setCode")
  @@schema("public")
}

model setDecks {
  setCode            String?
  code               String?
  name               String?
  type               String?
  releaseDate        String?
  source             String?
  sealedProductUuids String?
  sourceSetCodes     String?
  mainBoard          String?
  sideBoard          String?
  commander          String?
  displayCommander   String?
  tokens             String?
  planes             String?
  schemes            String?
  id                 Int     @id @default(autoincrement())
  sets               sets?   @relation(fields: [setCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_setdecks_setcode")

  @@index([setCode], map: "idx_setDecks_setCode")
  @@schema("public")
}

model setTranslations {
  code        String?
  language    String?
  translation String?
  id          Int     @id @default(autoincrement())
  sets        sets?   @relation(fields: [code], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_settranslations_code")

  @@index([code], map: "idx_setTranslations_code")
  @@schema("public")
}

model sets {
  code                     String                     @id
  mtgoCode                 String?
  name                     String?
  releaseDate              String?
  type                     String?
  isOnlineOnly             Boolean?
  isFoilOnly               Boolean?
  isNonFoilOnly            Boolean?
  totalSetSize             Int?
  baseSetSize              Int?
  keyruneCode              String?
  isPartialPreview         Boolean?
  isForeignOnly            Boolean?
  isPaperOnly              Boolean?
  languages                String?
  parentCode               String?
  tcgplayerGroupId         Int?
  tokenSetCode             String?
  mcmId                    Int?
  mcmName                  String?
  mcmIdExtras              Int?
  block                    String?
  cards                    cards[]
  sealedProducts           sealedProducts[]
  setBoosterContentWeights setBoosterContentWeights[]
  setBoosterContents       setBoosterContents[]
  setBoosterSheetCards     setBoosterSheetCards[]
  setBoosterSheets         setBoosterSheets[]
  setDecks                 setDecks[]
  setTranslations          setTranslations[]

  @@index([code], map: "idx_sets_code")
  @@index([name], map: "idx_sets_name")
  @@schema("public")
}

model tokenIdentifiers {
  uuid                              String  @id
  scryfallId                        String?
  scryfallOracleId                  String?
  scryfallIllustrationId            String?
  scryfallCardBackId                String?
  mcmId                             String?
  mcmMetaId                         String?
  mtgArenaId                        String?
  mtgoId                            String?
  mtgoFoilId                        String?
  multiverseId                      String?
  tcgplayerProductId                String?
  tcgplayerEtchedProductId          String?
  tcgplayerAlternativeFoilProductId String?
  cardKingdomId                     String?
  cardKingdomFoilId                 String?
  cardKingdomEtchedId               String?
  cardsphereId                      String?
  cardsphereAlternativeFoilId       String?
  cardsphereEtchedId                String?
  cardsphereFoilId                  String?
  deckboxId                         String?
  mtgjsonFoilVersionId              String?
  mtgjsonNonFoilVersionId           String?
  mtgjsonV4Id                       String?
  tokens                            tokens  @relation(fields: [uuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction, map: "fk_tokenidentifiers_uuid")

  @@index([uuid], map: "idx_tokenIdentifiers_uuid")
  @@schema("public")
}

model tokens {
  artist           String?
  artistIds        String?
  asciiName        String?
  attractionLights String?
  availability     String?
  boosterTypes     String?
  borderColor      String?
  colorIdentity    String?
  colorIndicator   String?
  colors           String?
  edhrecSaltiness  Float?
  faceName         String?
  finishes         String?
  flavorName       String?
  flavorText       String?
  frameEffects     String?
  frameVersion     String?
  isFullArt        Boolean?
  isFunny          Boolean?
  isOversized      Boolean?
  isPromo          Boolean?
  isReprint        Boolean?
  isTextless       Boolean?
  keywords         String?
  language         String?
  layout           String?
  manaCost         String?
  name             String?
  number           String?
  orientation      String?
  originalText     String?
  otherFaceIds     String?
  power            String?
  printedType      String?
  producedMana     String?
  promoTypes       String?
  relatedCards     String?
  securityStamp    String?
  setCode          String?
  side             String?
  signature        String?
  skuIds           String?
  sourceProducts   String?
  subtypes         String?
  supertypes       String?
  text             String?
  toughness        String?
  type             String?
  types            String?
  uuid             String            @id
  watermark        String?
  tokenIdentifiers tokenIdentifiers?

  @@index([name], map: "idx_tokens_name")
  @@index([setCode], map: "idx_tokens_setCode")
  @@index([uuid], map: "idx_tokens_uuid")
  @@schema("public")
}
